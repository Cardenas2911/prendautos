---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PageHero from "../components/PageHero.astro";
import FinalCta from "../components/FinalCta.astro";

const offices = [
  {
    href: "/oficinas-bogota",
    city: "Bogotá",
    title: "Oficina Chapinero",
    address: "Carrera 13 # 60-25, Local 102",
    hours: "Lunes a sábado, 8:00 am – 6:00 pm",
  },
  {
    href: "/oficinas-medellin",
    city: "Medellín",
    title: "Oficina El Poblado",
    address: "Calle 10 # 36-12, Edificio Avenida",
    hours: "Lunes a sábado, 8:00 am – 6:00 pm",
  },
];
---

<Layout
  title="Oficinas en Bogotá y Medellín | Prendautos"
  description="Atención presencial en Bogotá (Chapinero) y Medellín (El Poblado), o atención online a todo Colombia."
  activeNav="oficinas"
>
  <Breadcrumb items={[{ label: "Inicio", href: "/" }, { label: "Oficinas" }]} />

  <PageHero
    title="Visítanos "
    emphasis="en persona"
    titleSuffix="."
    lede="Atención presencial en Bogotá y Medellín, o atención online a todo Colombia."
    showCtas={false}
  />

  <section class="px-8 pt-[60px] pb-24">
    <div class="max-w-[1100px] mx-auto">
      <div class="grid md:grid-cols-2 gap-6">
        {
          offices.map((o) => (
            <a
              href={o.href}
              class="bg-white border border-border rounded-3xl p-10 transition-all hover:border-primary hover:-translate-y-0.5 hover:shadow-card-hover block"
            >
              <div class="font-mono text-xs text-accent tracking-widest uppercase font-semibold mb-4">
                {o.city}
              </div>
              <h3 class="text-[28px] font-extrabold tracking-[-0.025em] mb-3">
                {o.title}
              </h3>
              <p class="text-[15px] text-gray leading-relaxed mb-5">
                {o.address}
                <br />
                {o.hours}
              </p>
              <span class="text-sm text-primary font-semibold">
                Ver detalles →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <FinalCta />
</Layout>
