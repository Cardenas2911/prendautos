---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PageHero from "../components/PageHero.astro";
import ContentProse from "../components/ContentProse.astro";
import FinalCta from "../components/FinalCta.astro";
---

<Layout
  title="Préstamos sobre motos | Prendautos"
  description="Préstamo sobre tu moto sin entregarla. Para mensajeros, domiciliarios y motos particulares. Aprobación en 30 minutos."
  activeNav="prestamos"
>
  <Breadcrumb
    items={[
      { label: "Inicio", href: "/" },
      { label: "Préstamos", href: "/prestamos-vehiculos" },
      { label: "Motos" },
    ]}
  />

  <PageHero
    title="Préstamos sobre motos. "
    emphasis="Tu moto"
    titleSuffix=" también te respalda."
    lede="Si tu moto es tu medio de transporte o trabajo, puedes obtener liquidez sin entregarla. Mismo proceso ágil, montos adaptados."
  />

  <ContentProse>
    <h2>Préstamos diseñados para motos</h2>
    <p>
      Las motos representan en muchos casos el principal medio de trabajo
      (mensajería, domicilios, transporte personal). Sabemos que no puedes dejar
      la moto en custodia, así que aplicamos el mismo principio sin custodia que
      con carros.
    </p>

    <h2>Marcas elegibles</h2>
    <p>
      Trabajamos con la mayoría de marcas comerciales: AKT, Bajaj, Honda,
      Yamaha, Suzuki, KTM, Kawasaki, TVS, Royal Enfield, Pulsar, NS, KTM Duke,
      entre otras.
    </p>

    <h2>Montos referenciales</h2>
    <ul>
      <li>Motos de baja cilindrada (110–150cc): hasta $4.000.000</li>
      <li>Motos medianas (160–250cc): hasta $7.000.000</li>
      <li>Motos altas (250cc+): hasta $15.000.000</li>
    </ul>
    <p>
      El monto exacto depende del modelo, año y peritaje. Calcula el tuyo en el
      simulador.
    </p>

    <h2>Requisitos</h2>
    <ul>
      <li>Moto a tu nombre, máximo 8 años de antigüedad</li>
      <li>Tarjeta de propiedad y SOAT al día</li>
      <li>Cédula vigente</li>
      <li>Certificado de tradición sin gravámenes</li>
    </ul>
  </ContentProse>

  <FinalCta />
</Layout>
