---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import LoanLeadForm from "../components/LoanLeadForm.tsx";
import FinalCta from "../components/FinalCta.astro";

const trust = [
  { num: "30 min", lbl: "Para el desembolso" },
  { num: "Desde 2007", lbl: "Atendiendo en Medellín" },
  { num: "Sin", lbl: "Centrales de riesgo" },
  { num: "24/7", lbl: "Parqueadero vigilado" },
];

const empathy = [
  {
    title: "Lo necesito hoy",
    body:
      "Una urgencia, una oportunidad, un imprevisto. Te avaluamos el vehículo por WhatsApp y desembolsamos en 30 minutos en nuestra oficina de El Poblado.",
    tag: "Avalúo inmediato · Desembolso en 30 min",
    icon: '<circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>',
  },
  {
    title: "No quiero que revisen mi historial",
    body:
      "Aprobamos sobre el valor del vehículo, no sobre tu pasado crediticio. No consultamos centrales de riesgo.",
    tag: "Sin Datacrédito · Sin reportes",
    icon: '<path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>',
  },
  {
    title: "Quiero saber dónde queda mi carro",
    body:
      "Tu vehículo permanece en parqueadero cubierto y vigilado las 24 horas. Tomamos fotos al recibirlo para que se devuelva en el mismo estado.",
    tag: "Vigilancia 24/7 · Registro fotográfico",
    icon: '<path d="M3 12h1l1.5-5h13L20 12h1m-5 0a2 2 0 100 4 2 2 0 000-4zm-10 0a2 2 0 100 4 2 2 0 000-4z"/>',
  },
];

const steps = [
  {
    num: "PASO 01",
    title: "Solicitud y avalúo",
    desc: "Nos escribes por WhatsApp o llenas el formulario con la placa, marca, versión e identificación del propietario. Te damos el valor a prestar al instante.",
    time: "5 min",
  },
  {
    num: "PASO 02",
    title: "Visita la oficina",
    desc: "Te presentas en El Poblado (Edificio Platinum). Diligenciamos compraventa con pacto de retroventa, traspaso y poder.",
    time: "15 min",
  },
  {
    num: "PASO 03",
    title: "Autenticación",
    desc: "Autenticas los documentos en notaría (~$50.000 a tu cargo). Es el único costo externo del trámite.",
    time: "10 min",
  },
  {
    num: "PASO 04",
    title: "Desembolso en efectivo",
    desc: "Regresas con los documentos autenticados y recibes el dinero en efectivo de inmediato.",
    time: "5 min",
  },
];
---

<Layout
  title="Préstamos sobre Vehículos en Medellín | Empeño de Carros y Motos | Prendautos"
  description="¿Necesitas dinero rápido? En Prendautos Medellín te prestamos sobre tu carro o moto en 30 minutos. Sin centrales de riesgo, vehículos vigilados 24/7. ¡Visítanos!"
  activeNav="inicio"
>
  <!-- HERO -->
  <section class="px-4 sm:px-8 py-10 md:py-20 max-w-[1280px] mx-auto">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-20 items-center">
      <div>
        <div
          class="inline-flex gap-2 items-center bg-primary/10 text-primary font-mono text-xs px-3.5 py-1.5 rounded-full tracking-wider uppercase mb-6 font-medium"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
          Préstamos sobre vehículos en Medellín · desde 2007
        </div>

        <h1
          class="text-[40px] md:text-6xl lg:text-[72px] font-extrabold tracking-[-0.045em] leading-[1.05] mb-6"
        >
          Dinero
          <em class="not-italic text-primary relative inline-block">
            en 30 minutos
            <span
              aria-hidden="true"
              class="absolute left-0 right-0 bottom-1 h-3.5 bg-accent/25 -z-10 rounded"
            ></span>
          </em>
          dejando tu vehículo como garantía.
        </h1>

        <p class="text-xl text-gray leading-[1.55] max-w-[540px] mb-9">
          Préstamos sobre carros y motos en Medellín. Sin centrales de riesgo,
          parqueadero vigilado 24 horas y trámite directo en nuestra oficina de
          El Poblado.
        </p>

        <div class="flex gap-3 flex-wrap mb-10">
          <Button href="https://wa.me/573113547995" variant="primary" size="lg">
            Solicitar por WhatsApp →
          </Button>
          <Button href={`${import.meta.env.BASE_URL}/prestamos-vehiculos-medellin`} variant="outline" size="lg">
            ¿Cómo funciona?
          </Button>
        </div>

        <div class="flex gap-8 pt-8 border-t border-border flex-wrap">
          {
            trust.map((t) => (
              <div>
                <div class="text-[24px] sm:text-[28px] font-extrabold text-primary tracking-tight">
                  {t.num}
                </div>
                <div class="text-[13px] text-gray">{t.lbl}</div>
              </div>
            ))
          }
        </div>
      </div>

      <LoanLeadForm vehicleType="carro" variant="hero" client:load />
    </div>
  </section>

  <!-- EMPATHY -->
  <section class="bg-dark text-white px-4 sm:px-8 py-16 md:py-24">
    <div class="max-w-[1280px] mx-auto">
      <div class="mb-[60px]">
        <div
          class="font-mono text-[13px] text-accent font-medium tracking-widest uppercase mb-4"
        >
          Por qué elegir Prendautos Medellín
        </div>
        <h2
          class="text-4xl md:text-5xl font-extrabold tracking-[-0.035em] leading-[1.1] mb-5"
        >
          Rapidez y confianza<br />en un solo lugar.
        </h2>
        <p class="text-lg text-white/60 leading-relaxed max-w-[640px]">
          Llevamos casi dos décadas atendiendo personas que necesitan liquidez
          sin las complicaciones de la banca tradicional.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {
          empathy.map((e) => (
            <div class="bg-white/[0.04] border border-white/[0.08] rounded-3xl p-9">
              <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mb-6">
                <svg
                  width="28"
                  height="28"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#E8714A"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={e.icon}
                />
              </div>
              <h3 class="text-2xl font-bold tracking-tight mb-3">{e.title}</h3>
              <p class="text-base text-white/70 leading-relaxed mb-6">
                {e.body}
              </p>
              <div class="pt-5 border-t border-white/[0.08] font-mono text-xs text-white/55">
                {e.tag}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="px-4 sm:px-8 py-16 md:py-24">
    <div class="max-w-[1280px] mx-auto">
      <div class="mb-[60px]">
        <div
          class="font-mono text-[13px] text-accent font-medium tracking-widest uppercase mb-4"
        >
          Nuestros servicios
        </div>
        <h2
          class="text-4xl md:text-5xl font-extrabold tracking-[-0.035em] leading-[1.1] mb-5"
        >
          Tres formas de obtener<br />dinero rápido.
        </h2>
        <p class="text-lg text-gray leading-relaxed max-w-[640px]">
          Préstamos presenciales en Medellín y cambio de cupo de tarjeta de
          crédito 100% online a todo Colombia.
        </p>
      </div>

      <div class="grid lg:grid-cols-3 gap-4">
        <a
          href={`${import.meta.env.BASE_URL}/prestamos-vehiculos-medellin`}
          class="bg-primary text-white rounded-3xl p-9 transition-all hover:-translate-y-1 relative overflow-hidden flex flex-col"
        >
          <div
            class="w-12 h-12 rounded-2xl bg-white/15 flex items-center justify-center mb-5"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#fff"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 12h1l1.5-5h13L20 12h1m-5 0a2 2 0 100 4 2 2 0 000-4zm-10 0a2 2 0 100 4 2 2 0 000-4z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-2">
            Préstamos sobre vehículos
          </h3>
          <p class="text-[15px] text-white/80 leading-relaxed flex-1">
            Empeñamos tu carro y te prestamos efectivo el mismo día. Trámite
            presencial en nuestra oficina de El Poblado.
          </p>
          <span
            class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent"
          >
            Ver detalles →
          </span>
        </a>

        <a
          href={`${import.meta.env.BASE_URL}/prestamos-motos-medellin`}
          class="bg-white border border-border rounded-3xl p-9 transition-all hover:-translate-y-1 hover:border-primary flex flex-col"
        >
          <div
            class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center mb-5"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#0B6B5C"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="12" r="3"></circle>
              <path d="M9 12h6"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-2">
            Empeñar una moto
          </h3>
          <p class="text-[15px] text-gray leading-relaxed flex-1">
            Préstamo sobre tu moto sin importar el modelo. Recibimos motos de
            todos los años en parqueadero cubierto y vigilado.
          </p>
          <span class="mt-5 inline-block text-sm font-semibold text-primary">
            Cómo empeñar →
          </span>
        </a>

        <a
          href={`${import.meta.env.BASE_URL}/avances-tarjetas-de-credito`}
          class="bg-white border border-border rounded-3xl p-9 transition-all hover:-translate-y-1 hover:border-primary flex flex-col"
        >
          <div
            class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center mb-5"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#0B6B5C"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="6" width="20" height="12" rx="2"></rect>
              <path d="M2 10h20"></path>
            </svg>
          </div>
          <div class="inline-flex w-fit gap-1.5 items-center bg-accent/10 text-accent font-mono text-[10px] px-2 py-1 rounded-full tracking-wider uppercase mb-3 font-semibold">
            100% online · Toda Colombia
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-2">
            Cupo de tarjeta a efectivo
          </h3>
          <p class="text-[15px] text-gray leading-relaxed flex-1">
            Cambia el cupo de tu tarjeta de crédito por efectivo en tu cuenta
            bancaria en una hora. 100% en línea, desde cualquier ciudad.
          </p>
          <span class="mt-5 inline-block text-sm font-semibold text-primary">
            Ver cómo funciona →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-light px-4 sm:px-8 py-16 md:py-24">
    <div class="max-w-[1280px] mx-auto">
      <div class="mb-[60px]">
        <div
          class="font-mono text-[13px] text-accent font-medium tracking-widest uppercase mb-4"
        >
          Así funciona
        </div>
        <h2
          class="text-4xl md:text-5xl font-extrabold tracking-[-0.035em] leading-[1.1] mb-5"
        >
          De tu vehículo a tu bolsillo.<br />En 30 minutos.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {
          steps.map((s) => (
            <div class="bg-white rounded-3xl p-8 border border-border">
              <div class="font-mono text-[13px] text-accent font-semibold mb-6 tracking-widest">
                {s.num}
              </div>
              <div class="text-[19px] font-bold tracking-tight mb-2">
                {s.title}
              </div>
              <p class="text-sm text-gray leading-relaxed">{s.desc}</p>
              <span class="mt-5 font-mono text-xs text-primary bg-primary/10 px-2.5 py-1 rounded-full inline-block font-semibold">
                {s.time}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <FinalCta />
</Layout>
