---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PageHero from "../components/PageHero.astro";
import Simulator from "../components/Simulator.tsx";

const trust = [
  { strong: "30 min", label: "Tiempo de desembolso" },
  { strong: "Sin", label: "Datacrédito" },
  { strong: "100%", label: "Notariado" },
  { strong: "$0", label: "Penalidad por pre-pago" },
];
---

<Layout
  title="Simulador de préstamo sobre vehículo | Prendautos"
  description="Calcula tu préstamo sobre vehículo: monto, cuota mensual y plazo. Pre-aprobación inmediata en 2 minutos."
  activeNav="simulador"
>
  <Breadcrumb
    items={[{ label: "Inicio", href: "/" }, { label: "Simulador" }]}
  />

  <PageHero
    title="Calcula tu "
    emphasis="préstamo"
    titleSuffix="."
    lede="Ajusta el valor de tu vehículo y el plazo. Te decimos exactamente cuánto puedes recibir y cuánto pagarías al mes. Sin compromiso."
    showCtas={false}
  />

  <section class="px-8 pt-[60px] pb-24">
    <div class="max-w-[1100px] mx-auto">
      <Simulator client:load />

      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-[60px] pt-[60px] border-t border-border"
      >
        {
          trust.map((t) => (
            <div class="text-center">
              <strong class="block text-[28px] font-extrabold text-primary tracking-tight">
                {t.strong}
              </strong>
              <span class="text-[13px] text-gray font-mono">{t.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
