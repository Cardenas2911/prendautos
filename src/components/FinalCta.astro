---
import Button from "./Button.astro";

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  isAdvanceModal?: boolean;
}

const {
  title = "¿Necesitas plata hoy?\nTu vehículo la tiene.",
  subtitle = "Escríbenos por WhatsApp con la placa, marca y versión de tu vehículo. Te damos el avalúo al instante.",
  ctaText = "Solicitar por WhatsApp →",
  ctaHref = "https://wa.me/573113547995",
  isAdvanceModal = false,
} = Astro.props;

const lines = title.split("\n");
---

<section
  class="bg-primary text-white text-center relative overflow-hidden px-8 py-24"
>
  <div
    aria-hidden="true"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(232,113,74,0.25), transparent 70%);"
  >
  </div>
  <div class="max-w-[1280px] mx-auto relative">
    <h2
      class="text-4xl sm:text-5xl lg:text-[56px] font-extrabold tracking-[-0.04em] leading-[1.05] mb-5"
    >
      {lines.map((line, i) => (
        <>
          {line}
          {i < lines.length - 1 && <br />}
        </>
      ))}
    </h2>
    <p class="text-lg text-white/80 max-w-[600px] mx-auto mb-9 leading-[1.5]">
      {subtitle}
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <Button href={ctaHref} variant="accent" size="lg" data-advance-modal={isAdvanceModal ? "" : undefined}>
        {ctaText}
      </Button>
      <Button
        href="tel:+576045744341"
        variant="outline-light"
        size="lg"
      >
        Llamar ahora
      </Button>
    </div>
  </div>
</section>
