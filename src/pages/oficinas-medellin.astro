---
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PageHero from "../components/PageHero.astro";
import MapPlaceholder from "../components/MapPlaceholder.astro";
import FinalCta from "../components/FinalCta.astro";
---

<Layout
  title="Oficina Medellín El Poblado | Prendautos"
  description="Nuestra oficina original en El Poblado, Medellín, atendiendo desde 2007. Préstamos sobre vehículos con desembolso en 30 minutos."
  activeNav="oficinas"
>
  <Breadcrumb
    items={[
      { label: "Inicio", href: "/" },
      { label: "Oficinas", href: "/oficinas" },
      { label: "Medellín" },
    ]}
  />

  <PageHero
    title="Prendautos "
    emphasis="Medellín"
    titleSuffix="."
    lede="Nuestra oficina original. Atendemos en El Poblado desde 2007."
    showCtas={false}
  />

  <section class="px-8 pt-[60px] pb-24">
    <div
      class="max-w-[1000px] mx-auto grid md:grid-cols-2 gap-12 lg:gap-[60px] items-start"
    >
      <div class="office-info">
        <h2>Dirección</h2>
        <p>
          <strong>Calle 10 # 36-12, Edificio Avenida, Local 201</strong><br />
          El Poblado, Medellín
        </p>
        <h2>Horario</h2>
        <p>
          Lunes a viernes: 8:00 am – 6:00 pm<br />
          Sábados: 8:00 am – 1:00 pm<br />
          Domingos: cerrado
        </p>
        <h2>Contacto</h2>
        <p>
          WhatsApp: <a href="https://wa.me/573113547995">+57 311 354 7995</a><br
          />
          Correo: medellin@prendautos.co
        </p>
        <h2>Cómo llegar</h2>
        <ul>
          <li>Metro: estación Poblado (5 min en taxi)</li>
          <li>Buses que circulan por la Avenida El Poblado</li>
          <li>Parqueadero del edificio disponible</li>
        </ul>
      </div>

      <MapPlaceholder address="Calle 10 # 36-12" city="El Poblado, Medellín" />
    </div>
  </section>

  <FinalCta />
</Layout>
