---
interface Props {
  variant?: "color" | "white";
  size?: number;
}

const { variant = "color", size = 32 } = Astro.props;
const stroke = variant === "white" ? "#fff" : "#0B6B5C";
---

<a href={`${import.meta.env.BASE_URL}/`} class="flex items-center gap-2.5">
  <svg width={size} height={size} viewBox="0 0 200 200" aria-hidden="true">
    <path
      d="M 50 160 L 50 60 A 30 30 0 0 1 80 30 L 110 30 A 40 40 0 0 1 150 70 A 40 40 0 0 1 110 110 L 80 110"
      fill="none"
      stroke={stroke}
      stroke-width="20"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <circle cx="155" cy="160" r="11" fill="#E8714A"></circle>
  </svg>
  <span
    class:list={[
      "font-extrabold text-xl tracking-[-0.03em]",
      variant === "white" ? "text-white" : "text-primary",
    ]}
  >
    prend<span class="text-accent">autos</span>
  </span>
</a>
